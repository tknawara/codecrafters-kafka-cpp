{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/kimi-k2.5:cloud",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Cloud",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-agent": {
          "name": "qwen3-agent"
        },
        "kimi-k2.5:cloud": {
          "name": "kimi-k2.5:cloud",
          "id": "kimi-k2.5:cloud"
        }
      }
    }
  },
  "instructions": [
    "Always use snake_case for C++ variables.",
    "Follow 2-space indentation.",
    "Target C++23 standards."
  ],
  "permission": {
    "edit": "ask",
    "bash": "ask"
  }
}