# Find the running devcontainer for this workspace
export DC_CONTAINER=$(docker ps \
  --filter "label=devcontainer.local_folder=$PWD" \
  --format "{{.Names}}" | head -1)

if [ -z "$DC_CONTAINER" ]; then
    echo "⚠ No devcontainer running — open this folder in VSCode first"
else
    echo "✔ devcontainer: $DC_CONTAINER — run 'dce' to attach"
fi
