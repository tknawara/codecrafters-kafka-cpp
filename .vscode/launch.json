{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "MSVC: Debug",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/Debug/kafka.exe",
            "args": [
              "-E",
              "^I see \\d+ (cat|dog)s?$",
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "CMake: Build"
        }
    ]
}